    <string name="privacy_overview_text">SMS Forwarder (referred to as "we") takes your privacy very seriously. This privacy policy explains how we collect, use, store, and protect your personal information. By using our app, you agree to the practices described in this policy.</string>
    <string name="privacy_app_name">App Name: SMS Forwarder</string>
    <string name="privacy_developer">Developer: Huahao Technology Co., Ltd.</string>
    <string name="privacy_email">Contact Email: support@smsforwarder.cn</string>
    <string name="privacy_website">Official Website: https://smsforwarder.cn/</string>
    <string name="privacy_license">License: 鲁ICP备2026018166号-2A</string>
    <string name="privacy_principle_no_upload">No Cloud: All data is processed locally on your device and will not be uploaded to our servers</string>
    <string name="privacy_principle_no_collect">No Collection: We do not collect your personal information, SMS content, or other sensitive data</string>
    <string name="privacy_principle_no_track">No Tracking: No analytics, statistics, or advertising SDKs are integrated</string>
    <string name="privacy_principle_full_control">Full Control: All permissions and data are controlled by you</string>
    <string name="privacy_sms_content">SMS Content (Sensitive Information)</string>
    <string name="privacy_sms_purpose">Purpose: Only used locally on your device for keyword rule matching and forwarding</string>
    <string name="privacy_sms_storage">Storage: Not saved to any server, only processed temporarily during forwarding</string>
    <string name="privacy_sms_important">Important: The only time SMS content is sent is when you actively configure a Webhook forwarding target (such as WeChat Work, DingTalk, Feishu, or custom Webhook). The app sends SMS directly to your specified target without passing through our servers.</string>
    <string name="privacy_config">Configuration Information</string>
    <string name="privacy_config_text">Your configured forwarding channels, keyword rules, and other settings are stored locally on your device and will not be uploaded.</string>
    <string name="privacy_logs">Forwarding Logs</string>
    <string name="privacy_logs_text">The app records forwarding history locally (up to 200 entries) for your review and debugging. These logs are stored only on your device.</string>
    <string name="privacy_permission_sms">Receive SMS: Listens for incoming SMS on your device for forwarding</string>
    <string name="privacy_permission_notification">Notification: Displays foreground service notifications to show service status</string>
    <string name="privacy_permission_phone">Read Phone State: Identifies SIM card information and retrieves device phone number (optional)</string>
    <string name="privacy_permission_network">Network: Only used for forwarding to configured Webhooks</string>
    <string name="privacy_permission_foreground">Foreground Service: Keeps the app running stably in the background</string>
    <string name="privacy_permission_boot">Auto-start on Boot: Automatically starts forwarding service after device boot (optional)</string>
    <string name="privacy_permission_battery">Ignore Battery Optimization: Prevents the system from killing background services (optional)</string>
    <string name="privacy_permission_network_state">Access Network State: Detects network connection status</string>
    <string name="privacy_permission_camera">Camera: Used for scanning QR codes to import config (optional)</string>
    <string name="privacy_permission_note">All permissions require your active authorization and can be revoked at any time in system settings.</string>
    <string name="privacy_local_storage">Local Storage</string>
    <string name="privacy_local_text">All data is stored in your device's private directory, including:</string>
    <string name="privacy_local_channels">Forwarding channels and keyword configurations</string>
    <string name="privacy_local_logs">Forwarding history logs</string>
    <string name="privacy_local_settings">App settings</string>
    <string name="privacy_server_storage">Server Storage</string>
    <string name="privacy_server_text">We have no servers storing your data! The app is a purely local tool. We do not collect, store, or upload any user data.</string>
    <string name="privacy_right_view">View Data: View all forwarding logs in the app</string>
    <string name="privacy_right_delete">Delete Data: Clear logs in the app or uninstall to delete all data</string>
    <string name="privacy_right_control">Control Permissions: Grant or revoke permissions anytime in system settings</string>
    <string name="privacy_right_revoke">Revoke Consent: Revoke privacy policy consent in app settings</string>
    <string name="privacy_third_party_text">About Forwarding Targets: If you configure a Webhook or other third-party service as a forwarding target, SMS content will be sent to that third party. Please choose forwarding targets carefully and ensure you understand their privacy policies. We are not responsible for third-party data processing.</string>
    <string name="privacy_third_party_sdk">Third Party SDKs</string>
    <string name="privacy_third_party_sdk_text">No third-party SDKs are integrated in the current version (including analytics, advertising, crash analysis, etc.).</string>
    <string name="privacy_updates_text">We may update this privacy policy from time to time. For major changes, we will notify you through in-app notifications or other means. We recommend reviewing this policy regularly for the latest information.</string>
    <string name="privacy_contact_text">If you have any questions or suggestions about this privacy policy, please contact us at:</string>
    
